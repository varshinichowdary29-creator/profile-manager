# Express Backend Server Environment Variables

PORT=5000
NODE_ENV=development

# Authentication (JWT)
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=24h

# Database Dialect: sqlite or postgres
DB_DIALECT=sqlite

# SQLite Configuration (Used if DB_DIALECT is sqlite)
SQLITE_STORAGE=./database.sqlite

# PostgreSQL Configuration (Used if DB_DIALECT is postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=intellitots_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# OpenAI API Settings (For future AI enhancements)
OPENAI_API_KEY=your_openai_api_key_here

# Email Service Settings (For parent alert notifications)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_smtp_user_here
EMAIL_PASSWORD=your_smtp_password_here
